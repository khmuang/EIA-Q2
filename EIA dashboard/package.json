{
  "name": "eia-dashboard-css",
  "version": "1.0.0",
  "description": "Production CSS Builder for EIA Dashboard",
  "scripts": {
    "build": "npx @tailwindcss/cli -i ./input.css -o ./dist/output.css --minify",
    "build-dev": "npx @tailwindcss/cli -i ./input.css -o ./dist/output.css",
    "watch": "npx @tailwindcss/cli -i ./input.css -o ./dist/output.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  }
}